  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@unocss/core": "^66.6.8",
    "@unocss/preset-mini": "^66.6.8",
    "@unocss/rule-utils": "^66.6.8",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vue-tsc": "^3.2.6"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  }
