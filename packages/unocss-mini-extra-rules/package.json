      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@unocss/core": ">=0.60.0 <1.0.0",
    "@unocss/preset-mini": ">=0.60.0 <1.0.0",
