{
  "name": "@feugene/unocss-mini-extra-rules",
  "description": "Extra UnoCSS rules on top of @unocss/preset-mini: animations, bracket color with opacity, advanced filters and spacing utilities.",
  "version": "0.2.0",
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Evgeniy Fureev",
    "url": "https://github.com/efureev"
  },
  "homepage": "https://github.com/efureev/unocss-preset-granular#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/efureev/unocss-preset-granular.git",
    "directory": "packages/unocss-mini-extra-rules"
  },
  "bugs": {
    "url": "https://github.com/efureev/unocss-preset-granular/issues"
  },
  "keywords": [
    "unocss",
    "unocss-rules",
    "unocss-preset-mini",
    "rules",
    "preset",
    "atomic-css",
    "css-in-js"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
